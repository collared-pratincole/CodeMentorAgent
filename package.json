{
  "name": "codementor-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "electron:dev": "concurrently \"npm run server\" \"wait-on http://localhost:3001 && electron electron/main.cjs\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win --x64",
    "electron:dist": "npm run build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "dexie": "^4.0.9",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.511.0",
    "mermaid": "^11.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.3.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.codementor.ai",
    "productName": "CodeMentor AI",
    "copyright": "Copyright © 2026 CodeMentor AI",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!node_modules/.cache/**/*",
          "!node_modules/.bin/**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "CodeMentor-AI-Setup-${version}-${arch}.exe",
      "electronDist": ".electron-dist/win-unpacked"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CodeMentor AI",
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "language": "2052"
    }
  }
}
